{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "checklist.schema.json",
  "title": "Pre-Departure Checklist",
  "description": "Schema for Haven garden pre-departure checklist data",
  "type": "object",
  "required": ["checklist_type", "departure_date", "return_date", "days"],
  "properties": {
    "checklist_type": {
      "type": "string",
      "enum": ["pre-departure"]
    },
    "departure_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Departure date in ISO 8601 format, null if not yet confirmed"
    },
    "return_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Return date in ISO 8601 format, null if not yet confirmed"
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["day", "label", "tasks"],
        "properties": {
          "day": {
            "type": "integer",
            "maximum": -1,
            "description": "Relative day number (negative, counting down to departure)"
          },
          "label": {
            "type": "string",
            "description": "Human-readable day name"
          },
          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "action", "who", "minutes", "completed"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^D[0-9]+-[0-9]{2}$",
                  "description": "Task ID in format D{day}-{sequence}, e.g. D3-01"
                },
                "action": {
                  "type": "string",
                  "description": "Concrete action description"
                },
                "who": {
                  "type": "string",
                  "enum": ["father", "child", "together"],
                  "description": "Who performs this task"
                },
                "minutes": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Estimated duration in minutes"
                },
                "completed": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether the task has been completed"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
